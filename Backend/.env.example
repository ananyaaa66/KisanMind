# ── Main LLM (change LLM_PROVIDER to "groq" if Gemini rate-limits) ──
LLM_PROVIDER=groq
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL_NAME=llama-3.3-70b-versatile

# ── Groq backup (switch LLM_PROVIDER to "groq" and swap LLM_API_KEY to this) ──
GROQ_API_KEY=your_groq_api_key_here
AGENT_NAME=llama-3.3-70b-versatile

# ── Gemini Vision (Disease agent — always uses Gemini) ──
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_VISION_MODEL=gemini-2.5-flash

# ── Tavily (Market + Scheme agents — live web search) ──
TAVILY_API_KEY=your_tavily_api_key_here

# ── OpenWeatherMap (Weather agent) ──
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# ── Local paths (don't change) ──
CHROMA_DB_PATH=./chroma_db
SQLITE_DB_PATH=./memory.db
